// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "ui_font_size": 16,
  "blinking": "terminal_controlled",
  "format_on_save": "on",
  "preferred_line_length": 120,
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "vim_mode": true,
  "relative_line_numbers": true,
  "theme": "Catppuccin Macchiato",
  "experimental.theme_overrides": {
    "background.appearance": "transparent",
    "background": "#24273a90",
    "editor.background": "#24273a50",
    "terminal.background": "#24273a50",
    "panel.background": "#1e203050",
    "tab_bar.background": "#18192650",
    "toolbar.background": "#24273a50",
    "status_bar.background": "#18192650",
    "title_bar.background": "#d1dae4ff",
    "editor.gutter.background": "#24273a50",
    "tab.active_background": "#24273af0",
    "tab.inactive_background": "#1e203015"
  },
  "buffer_font_family": "MonoLisa Nerd Font",
  "buffer_font_weight": 300,
  "buffer_font_size": 13,
  "buffer_font_features": {
    "liga": false
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "show_whitespaces": "boundary",
  "inlay_hints": {
    "enabled": true,
    "max_length": 15,
    "show_type_hints": true,
    "show_parameter_hints": false,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": 15,
          "lifetimeElisionHints": {
            "useParameterNames": true,
            "enable": "skip_trivial"
          },
          "closureReturnTypeHints": {
            "enable": "always"
          }
        }
      }
    },
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    },
    "elixir-ls": {
      "settings": {
        "dialyzerEnabled": true,
        "incrementalDialyzer": true,
        "autoBuild": true
      }
    }
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "scrollbar": {
    "show": "always"
  },
  "terminal": {
    "copy_on_select": true,
    "toolbar": {
      "title": false
    }
  },
  "assistant": {
    "version": "1",
    "provider": {
      "default_model": "claude-3-5-sonnet-20240620",
      "name": "anthropic"
    }
  }
}
